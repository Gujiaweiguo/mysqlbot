# Copy this file to .env before running local or containerized startup.
# Replace placeholder values with deployment-specific secrets.

# --- Required secrets / bootstrap values ---
SQLBOT_SECRET_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
SQLBOT_PG_PASSWORD=CHANGE_ME_DB_PASSWORD
SQLBOT_DEFAULT_PWD=CHANGE_ME_ADMIN_PASSWORD

# --- Database ---
SQLBOT_PG_DB=sqlbot
SQLBOT_PG_USER=root
SQLBOT_PG_PORT=5432

# --- Cache ---
SQLBOT_CACHE_TYPE=memory
SQLBOT_CACHE_REDIS_URL=redis://redis:6379/0

# --- Data directories ---
SQLBOT_DATA_DIR=./data/sqlbot
SQLBOT_PG_DATA_DIR=./data/postgresql
SQLBOT_REDIS_DATA_DIR=./data/redis

# --- Runtime and CORS ---
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,https://localhost,https://localhost:5173
SERVER_IMAGE_HOST=http://YOUR_SERVER_IP:MCP_PORT/images/
LOG_LEVEL=INFO
SQL_DEBUG=false

# --- Embedding runtime ---
EMBEDDING_PROVIDER=remote
EMBEDDING_STARTUP_BACKFILL_POLICY=deferred
REMOTE_EMBEDDING_BASE_URL=
REMOTE_EMBEDDING_API_KEY=
REMOTE_EMBEDDING_MODEL=
REMOTE_EMBEDDING_TIMEOUT_SECONDS=30
