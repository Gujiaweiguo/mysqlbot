# ========================================
# mySQLBot 环境变量模板
# ========================================
# 开发环境：复制为 .env，修改本地后端需要的变量
# 生产环境：通过 installer/install.conf 安装，自动生成运行目录配置

# ----------------------------------------
# 开发环境配置（本地运行 backend + frontend）
# ----------------------------------------

# --- 数据库（连接本地运行的 postgresql 容器） ---
# 开发环境端口：15432（避免与本地已有 postgresql 冲突）
SQLBOT_DEV_PG_HOST=localhost
SQLBOT_DEV_PG_PORT=15432
SQLBOT_DEV_PG_DB=sqlbot
SQLBOT_DEV_PG_USER=sqlbot_user
SQLBOT_DEV_PG_PASSWORD=DevOnly@123456

# --- 缓存（默认不启用，如需启用 redis 请改为 redis 并配置 URL） ---
# 开发环境 redis 端口：16379（避免与本地已有 redis 冲突）
SQLBOT_CACHE_TYPE=memory
SQLBOT_CACHE_REDIS_URL=redis://localhost:16379/0

# --- 安全 ---
SQLBOT_SECRET_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET

# --- 默认管理员密码 ---
SQLBOT_DEFAULT_PWD=mySQLBot@123456

# --- 后端运行 ---
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:8000,http://localhost:5173
SERVER_IMAGE_HOST=http://localhost:8001/images/
LOG_LEVEL=DEBUG
SQL_DEBUG=false

# --- 数据源异步同步（默认关闭，按环境灰度开启） ---
# DATASOURCE_ASYNC_SYNC_ENABLED=false
# DATASOURCE_ASYNC_SYNC_TABLE_THRESHOLD=100
# DATASOURCE_SYNC_JOB_MAX_WORKERS=4
# DATASOURCE_SYNC_JOB_STALE_TIMEOUT_SECONDS=3600
# DATASOURCE_SYNC_JOB_PROGRESS_INTERVAL_SECONDS=2
# DATASOURCE_SYNC_EMBEDDING_CHUNK_SIZE=50

# --- 向量嵌入 ---
EMBEDDING_PROVIDER=remote
EMBEDDING_STARTUP_BACKFILL_POLICY=deferred
REMOTE_EMBEDDING_BASE_URL=
REMOTE_EMBEDDING_API_KEY=
REMOTE_EMBEDDING_MODEL=
REMOTE_EMBEDDING_TIMEOUT_SECONDS=30

# ----------------------------------------
# 开发环境 Compose 变量（docker-compose.dev.yaml 使用）
# ----------------------------------------
SQLBOT_DEV_PG_DATA_DIR=./data/sqlbot/dev/postgresql
SQLBOT_DEV_REDIS_DATA_DIR=./data/sqlbot/dev/redis
SQLBOT_DEV_REDIS_PORT=16379
